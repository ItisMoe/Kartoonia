<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <uses-permission android:name="android.permission.INTERNET"/>
    <!-- Write Google TV / Android TV home-screen recommendation channels -->
    <uses-permission android:name="com.android.providers.tv.permission.WRITE_EPG_DATA"/>
    <!-- Voice search: record audio for on-device speech recognition -->
    <uses-permission android:name="android.permission.RECORD_AUDIO"/>

    <!-- Runs on both Android TV / Google TV (leanback, no touchscreen) AND
         touch phones/tablets. Nothing is required, so the app installs on every
         form factor: leanback-only TVs, and phones that lack a leanback UI. -->
    <uses-feature android:name="android.software.leanback" android:required="false"/>
    <uses-feature android:name="android.hardware.touchscreen" android:required="false"/>
    <!-- Mic is optional: TVs without one still install (voice button hides itself) -->
    <uses-feature android:name="android.hardware.microphone" android:required="false"/>

    <application
        android:label="Kartoonia"
        android:name="${applicationName}"
        android:banner="@drawable/banner"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:icon="@mipmap/ic_launcher"
            android:roundIcon="@mipmap/ic_launcher"
            android:banner="@drawable/banner"
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:screenOrientation="sensorLandscape"
            android:windowSoftInputMode="adjustResize"
            android:resizeableActivity="true">
            <meta-data
              android:name="io.flutter.embedding.android.NormalTheme"
              android:resource="@style/NormalTheme"
              />
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
                <!-- Show on the Android TV / Google TV home row -->
                <category android:name="android.intent.category.LEANBACK_LAUNCHER"/>
            </intent-filter>
            <!-- Deep links from home-screen recommendation programs -->
            <intent-filter>
                <action android:name="android.intent.action.VIEW"/>
                <category android:name="android.intent.category.DEFAULT"/>
                <category android:name="android.intent.category.BROWSABLE"/>
                <data android:scheme="kartoonia"/>
            </intent-filter>
        </activity>
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />
    </application>
    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT"/>
            <data android:mimeType="text/plain"/>
        </intent>
        <!-- Discover the system speech recognizer on Android 11+ (package visibility) -->
        <intent>
            <action android:name="android.speech.RecognitionService"/>
        </intent>
        <!-- Resolve the system voice-input dialog (RecognizerIntent) used for voice search -->
        <intent>
            <action android:name="android.speech.action.RECOGNIZE_SPEECH"/>
        </intent>
    </queries>
</manifest>
