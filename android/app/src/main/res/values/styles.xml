<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Theme applied to the Android Window while the process is starting.
         Dark, NoTitleBar so the branded launch screen fills the screen with no
         white flash. Automatically removed when Flutter draws its first frame. -->
    <style name="LaunchTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">@drawable/launch_background</item>
    </style>
    <!-- Theme applied as soon as the process has started; determines the color
         behind the Flutter UI while it initializes (kept dark to avoid a flash). -->
    <style name="NormalTheme" parent="@android:style/Theme.Black.NoTitleBar">
        <item name="android:windowBackground">@color/kartoonia_bg</item>
    </style>
</resources>
